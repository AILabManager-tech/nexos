{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nexos.modules.brief-preview-scorer.output",
  "title": "BriefPreviewScorerOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["module_id", "estimated_mu", "dimensions", "confidence", "gating_factors"],
  "properties": {
    "module_id": {
      "const": "brief-preview-scorer"
    },
    "estimated_mu": {
      "type": "number",
      "minimum": 0,
      "maximum": 10
    },
    "dimensions": {
      "type": "object",
      "patternProperties": {
        "^D[1-9]$": {
          "type": "object",
          "required": ["score", "name", "rationale"],
          "properties": {
            "score": {"type": "number", "minimum": 0, "maximum": 10},
            "name": {"type": "string"},
            "rationale": {"type": "string"}
          }
        }
      },
      "additionalProperties": false
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "0=brief vide, 1=brief totalement renseigné"
    },
    "gating_factors": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Champs manquants qui plafonnent le score estimé."
    }
  }
}
