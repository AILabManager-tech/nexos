{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nexos.modules.pattern-prerecommender.input",
  "title": "PatternPreRecommenderInput",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "brief": {
      "type": "object",
      "description": "Brief canonique (facultatif si sector_id est fourni)."
    },
    "sector_id": {
      "type": "string",
      "pattern": "^SEC-[0-9]{2}$",
      "description": "ID secteur (SEC-01 .. SEC-06). Si absent, dérivé du brief."
    },
    "top_k": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 3
    }
  }
}
