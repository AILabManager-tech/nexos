{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nexos.modules.brief-synthesizer.input",
  "title": "BriefSynthesizerInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["company"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["create", "audit", "modify", "content", "analyze"],
      "default": "create"
    },
    "company_name": {
      "type": "string",
      "minLength": 1
    },
    "company": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "slug": { "type": "string", "minLength": 1 },
        "neq": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "legal": {
      "type": "object"
    },
    "site": {
      "type": "object"
    },
    "design": {
      "type": "object"
    },
    "context": {
      "type": "object"
    },
    "adaptive": {
      "type": "object"
    },
    "mission": {
      "type": "object"
    },
    "sector": {
      "type": "string",
      "description": "Secteur d'activité (ex: epicerie, avocat, clinique). Lu par pattern_prerecommender au top-level brief.",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "description": "Étiquettes libres (multi-valeurs) pour catégorisation interne / SaaS preview.",
      "items": { "type": "string", "minLength": 1 },
      "maxItems": 20
    },
    "notes": {
      "type": "string",
      "description": "Notes libres opérateur — pas utilisé par le pipeline, conservé tel quel.",
      "maxLength": 2000
    }
  }
}
