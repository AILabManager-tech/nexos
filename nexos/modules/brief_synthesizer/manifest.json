{
  "id": "brief-synthesizer",
  "name": "Brief Synthesizer",
  "version": "0.1.0",
  "description": "Transforme un intake réduit en brief-client.json canonique et expose les champs bloquants restants.",
  "package": "nexos.modules.brief_synthesizer",
  "entrypoint": "run",
